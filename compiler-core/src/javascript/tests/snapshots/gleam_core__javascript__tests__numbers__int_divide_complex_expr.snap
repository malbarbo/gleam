fn go() {
  case 1 >= 0 {
    True -> 2
    False -> 4
  } / 2
}


----- COMPILED JAVASCRIPT
import { divideInt } from "../gleam.mjs";

function go() {
  return divideInt(
    (() => {
      let $ = 1n >= 0n;
      if ($) {
        return 2n;
      } else {
        return 4n;
      }
    })(),
    2n
  );
}
