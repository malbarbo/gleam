----- SOURCE CODE
pub fn main(f, x) {
  f(case x {
    1 -> 2
    _ -> 0
  })
}


----- COMPILED JAVASCRIPT
export function main(f, x) {
  return f(
    (() => {
      if (x === 1n) {
        return 2n;
      } else {
        return 0n;
      }
    })(),
  );
}
