----- SOURCE CODE

fn go() {
    1 + 1 // => 2
    5 - 1 // => 4
    5 / 2 // => 2
    3 * 3 // => 9
    5 % 2 // => 1
    2 > 1  // => True
    2 < 1  // => False
    2 >= 1 // => True
    2 <= 1 // => False
}


----- COMPILED JAVASCRIPT
import { remainderInt, divideInt } from "../gleam.mjs";

function go() {
  1n + 1n;
  5n - 1n;
  divideInt(5n, 2n);
  3n * 3n;
  remainderInt(5n, 2n);
  2n > 1n;
  2n < 1n;
  2n >= 1n;
  return 2n <= 1n;
}
